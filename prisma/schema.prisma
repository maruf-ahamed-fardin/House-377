generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum NoticePriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum ExpenseCategory {
  ELECTRICITY
  GAS
  INTERNET
  CLEANING
  MAINTENANCE
  WATER
  OTHER
}

enum RentDistributionMode {
  EQUAL
  PROFILE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                         String                       @id @default(cuid())
  email                      String                       @unique
  emailVerified              DateTime?
  passwordHash               String?
  role                       Role                         @default(MEMBER)
  name                       String
  image                      String?
  phone                      String?
  isActive                   Boolean                      @default(true)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime                     @updatedAt
  memberProfile              MemberProfile?
  accounts                   Account[]
  sessions                   Session[]
  messages                   ChatMessage[]                @relation("ChatSender")
  timelinePosts              TimelinePost[]               @relation("TimelineAuthor")
  noticesCreated             Notice[]                     @relation("NoticeCreatedBy")
  mealUpdates                MealRecord[]                 @relation("MealUpdatedBy")
  bazarExpensesCreated       BazarExpense[]               @relation("BazarCreatedBy")
  bazarSchedulesCreated      BazarSchedule[]              @relation("BazarScheduleCreatedBy")
  bazarChangeRequests        BazarScheduleChangeRequest[] @relation("BazarScheduleRequestedBy")
  bazarChangeRequestsHandled BazarScheduleChangeRequest[] @relation("BazarScheduleHandledBy")
  rentPaymentsCreated        RentPayment[]                @relation("RentPaymentCreatedBy")
  otherExpensesCreated       OtherExpense[]               @relation("OtherExpenseCreatedBy")
  depositsCreated            Deposit[]                    @relation("DepositCreatedBy")
  importantInfoUpdated       ImportantInfo[]              @relation("ImportantInfoUpdatedBy")
  monthlySummariesUpdated    MonthlySummary[]             @relation("MonthlySummaryUpdatedBy")
  auditActions               AuditLog[]                   @relation("AuditActor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MemberProfile {
  id               String          @id @default(cuid())
  userId           String          @unique
  permanentAddress String
  roomNumber       String
  joiningDate      DateTime
  status           MemberStatus    @default(ACTIVE)
  guardianPhone    String?
  monthlyRentShare Decimal         @default(0)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals            MealRecord[]
  bazarExpenses    BazarExpense[]  @relation("BazarBuyer")
  bazarSchedules   BazarSchedule[] @relation("BazarScheduleMember")
  rentPayments     RentPayment[]   @relation("RentPayer")
  otherExpenses    OtherExpense[]  @relation("OtherExpensePaidBy")
  deposits         Deposit[]       @relation("DepositMember")
}

model MealRecord {
  id             String        @id @default(cuid())
  memberId       String
  date           DateTime
  monthKey       String
  breakfastCount Decimal       @default(0)
  lunchCount     Decimal       @default(0)
  dinnerCount    Decimal       @default(0)
  notes          String?
  updatedById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  member         MemberProfile @relation(fields: [memberId], references: [id], onDelete: Cascade)
  updatedBy      User          @relation("MealUpdatedBy", fields: [updatedById], references: [id])

  @@unique([memberId, date])
  @@index([monthKey])
}

model BazarExpense {
  id          String         @id @default(cuid())
  itemName    String
  quantity    Decimal        @default(1)
  unit        String?
  price       Decimal
  date        DateTime
  monthKey    String
  boughtById  String?
  receiptUrl  String?
  notes       String?
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  boughtBy    MemberProfile? @relation("BazarBuyer", fields: [boughtById], references: [id], onDelete: SetNull)
  createdBy   User           @relation("BazarCreatedBy", fields: [createdById], references: [id])

  @@index([monthKey])
  @@index([boughtById])
}

model RentPayment {
  id          String        @id @default(cuid())
  memberId    String
  amount      Decimal
  date        DateTime
  monthKey    String
  notes       String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  member      MemberProfile @relation("RentPayer", fields: [memberId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("RentPaymentCreatedBy", fields: [createdById], references: [id])

  @@index([monthKey])
  @@index([memberId])
}

model OtherExpense {
  id          String          @id @default(cuid())
  title       String
  category    ExpenseCategory
  amount      Decimal
  date        DateTime
  monthKey    String
  paidById    String?
  notes       String?
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  paidBy      MemberProfile?  @relation("OtherExpensePaidBy", fields: [paidById], references: [id], onDelete: SetNull)
  createdBy   User            @relation("OtherExpenseCreatedBy", fields: [createdById], references: [id])

  @@index([monthKey])
  @@index([paidById])
}

model Deposit {
  id          String        @id @default(cuid())
  memberId    String
  amount      Decimal
  date        DateTime
  monthKey    String
  purpose     String?
  notes       String?
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  member      MemberProfile @relation("DepositMember", fields: [memberId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("DepositCreatedBy", fields: [createdById], references: [id])

  @@index([monthKey])
  @@index([memberId])
}

model Notice {
  id          String         @id @default(cuid())
  title       String
  description String
  priority    NoticePriority @default(NORMAL)
  date        DateTime       @default(now())
  isPublished Boolean        @default(true)
  createdById String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdBy   User           @relation("NoticeCreatedBy", fields: [createdById], references: [id])

  @@index([date])
}

model ImportantInfo {
  id                 String   @id @default(cuid())
  electricityAccount String?
  gasCardNumber      String?
  wifiInfo           String?
  houseOwnerPhone    String?
  emergencyContacts  Json?
  nearbyDoctorInfo   String?
  nearbyPharmacyInfo String?
  otherNotes         String?
  membersCanView     Boolean  @default(true)
  updatedById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  updatedBy          User     @relation("ImportantInfoUpdatedBy", fields: [updatedById], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sender    User     @relation("ChatSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model BazarSchedule {
  id             String                       @id @default(cuid())
  memberId       String
  date           DateTime                     @unique
  monthKey       String
  notes          String?
  createdById    String
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt
  member         MemberProfile                @relation("BazarScheduleMember", fields: [memberId], references: [id], onDelete: Cascade)
  createdBy      User                         @relation("BazarScheduleCreatedBy", fields: [createdById], references: [id])
  changeRequests BazarScheduleChangeRequest[]

  @@index([monthKey])
  @@index([memberId])
}

model BazarScheduleChangeRequest {
  id                String        @id @default(cuid())
  scheduleId        String
  requesterId       String
  requestedDate     DateTime
  requestedMonthKey String
  reason            String
  status            RequestStatus @default(PENDING)
  adminNote         String?
  handledById       String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  schedule          BazarSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  requester         User          @relation("BazarScheduleRequestedBy", fields: [requesterId], references: [id], onDelete: Cascade)
  handledBy         User?         @relation("BazarScheduleHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([scheduleId])
  @@index([requesterId])
  @@index([status, createdAt])
  @@index([requestedMonthKey])
}

model TimelinePost {
  id         String   @id @default(cuid())
  authorId   String
  title      String?
  content    String
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("TimelineAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([authorId])
}

model MonthlySummary {
  id                   String               @id @default(cuid())
  monthKey             String               @unique
  totalHouseRent       Decimal              @default(0)
  rentDistributionMode RentDistributionMode @default(EQUAL)
  notes                String?
  updatedById          String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  updatedBy            User                 @relation("MonthlySummaryUpdatedBy", fields: [updatedById], references: [id])
}

model AuditLog {
  id            String   @id @default(cuid())
  action        String
  entityType    String
  entityId      String
  performedById String?
  timestamp     DateTime @default(now())
  metadata      Json?
  performedBy   User?    @relation("AuditActor", fields: [performedById], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([timestamp])
}
